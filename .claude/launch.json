{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Dev (Turbopack)",
      "runtimeExecutable": "cmd.exe",
      "runtimeArgs": ["/d", "/s", "/c", "npm run dev"],
      "port": 3000
    },
    {
      "name": "Next.js Dev HTTPS (Turbopack)",
      "runtimeExecutable": "cmd.exe",
      "runtimeArgs": ["/d", "/s", "/c", "npm run dev:fast"],
      "port": 3000
    },
    {
      "name": "Next.js Production Preview",
      "runtimeExecutable": "cmd.exe",
      "runtimeArgs": ["/d", "/s", "/c", "npm run start"],
      "port": 3000
    }
  ]
}
