# Supabase Configuration
# Get these from your Supabase project settings: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Encryption Key
# IMPORTANT: Generate a secure 32-character key for client-side encryption
# This should be kept secret and never committed to version control
# You can generate one at: https://randomkeygen.com/ or use: openssl rand -base64 32
NEXT_PUBLIC_ENCRYPTION_KEY=your_32_character_encryption_key_here

# Development (optional)
NEXT_PUBLIC_APP_URL=http://localhost:3000
